# Playwright image for verify's browser gate
# Build: docker build -t verify-playwright:latest -f fixtures/Dockerfile.playwright .
# Used by src/gates/browser.ts to validate CSS/HTML predicates via getComputedStyle()

FROM mcr.microsoft.com/playwright:v1.49.0-noble

WORKDIR /app

# No install needed — playwright ships pre-installed in the base image
# The browser-gate-runner.mjs is volume-mounted at runtime
