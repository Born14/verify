{
  "version": 1,
  "resources": [
    {
      "address": "aws_db_instance.production",
      "type": "aws_db_instance",
      "id": "demo-db-production",
      "critical": true,
      "attributes": {
        "engine": "postgres",
        "deletion_protection": "true",
        "tags.Environment": "production"
      }
    },
    {
      "address": "aws_db_instance.staging",
      "type": "aws_db_instance",
      "id": "demo-db-staging",
      "critical": false,
      "attributes": {
        "engine": "postgres",
        "deletion_protection": "false",
        "tags.Environment": "staging"
      }
    },
    {
      "address": "aws_s3_bucket.assets",
      "type": "aws_s3_bucket",
      "id": "demo-assets-bucket",
      "critical": false,
      "attributes": {
        "acl": "private",
        "tags.Environment": "production"
      }
    },
    {
      "address": "aws_security_group.web",
      "type": "aws_security_group",
      "id": "sg-demo-web",
      "critical": false,
      "attributes": {
        "vpc_id": "vpc-demo",
        "tags.Environment": "production"
      }
    }
  ]
}
